{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"./project.schema.json","title":"Project metadata schema","description":"Validates project.yaml canonical repository metadata.","type":"object","additionalProperties":false,"required":["schema_version","repository","maturity","agent_mode"],"properties":{"schema_version":{"$ref":"common.schema.json#/$defs/schema_version"},"repository":{"type":"object","additionalProperties":false,"required":["name","version"],"properties":{"name":{"const":"gpante-seo-os"},"version":{"type":"string","pattern":"^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"}}},"maturity":{"type":"object","additionalProperties":false,"required":["stage","first_real_run_started","production_operational"],"properties":{"stage":{"enum":["foundation"]},"first_real_run_started":{"type":"boolean"},"production_operational":{"type":"boolean"}}},"agent_mode":{"type":"object","additionalProperties":false,"required":["default_access","repository_write","production_write"],"properties":{"default_access":{"enum":["read_only"]},"repository_write":{"enum":["pull_request_only"]},"production_write":{"enum":["prohibited_by_default"]}}}}}
