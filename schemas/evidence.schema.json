{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./evidence.schema.json",
  "title": "Evidence schema",
  "description": "Validates Run-local Evidence YAML front matter. Evidence metadata follows policies/evidence-policy.md and policies/data-policy.md; narrative remains in Markdown body.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "is_template",
    "evidence_id",
    "title",
    "owner",
    "collected_at",
    "source_type",
    "scope",
    "classification",
    "sanitized",
    "storage",
    "related_run",
    "related_findings"
  ],
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schema_version"
    },
    "record_type": {
      "const": "evidence"
    },
    "is_template": {
      "type": "boolean"
    },
    "evidence_id": {},
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {},
    "collected_at": {},
    "source_type": {
      "type": "string"
    },
    "classification": {
      "type": "string",
      "enum": [
        "repository-safe",
        "sanitization-required",
        "reference-only",
        "prohibited"
      ]
    },
    "related_run": {},
    "related_findings": {},
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "sanitized": {
      "type": "boolean"
    },
    "storage": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "is_template": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "evidence_id": {
            "oneOf": [
              {
                "$ref": "common.schema.json#/$defs/evidence_id"
              },
              {
                "$ref": "common.schema.json#/$defs/evidence_id_template"
              }
            ]
          },
          "owner": {
            "oneOf": [
              {
                "$ref": "common.schema.json#/$defs/real_owner"
              },
              {
                "$ref": "common.schema.json#/$defs/template_owner"
              }
            ]
          },
          "collected_at": {
            "$ref": "common.schema.json#/$defs/iso_date"
          },
          "related_run": {
            "oneOf": [
              {
                "$ref": "common.schema.json#/$defs/run_id"
              },
              {
                "$ref": "common.schema.json#/$defs/run_id_template"
              }
            ]
          },
          "related_findings": {
            "$ref": "common.schema.json#/$defs/finding_id_array_template"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "is_template": {
            "const": false
          }
        }
      },
      "then": {
        "properties": {
          "evidence_id": {
            "$ref": "common.schema.json#/$defs/evidence_id"
          },
          "owner": {
            "$ref": "common.schema.json#/$defs/real_owner"
          },
          "collected_at": {
            "$ref": "common.schema.json#/$defs/real_iso_date"
          },
          "classification": {
            "not": {
              "const": "prohibited"
            }
          },
          "related_run": {
            "$ref": "common.schema.json#/$defs/run_id"
          },
          "related_findings": {
            "$ref": "common.schema.json#/$defs/finding_id_array"
          }
        },
        "allOf": [
          {
            "if": {
              "required": [
                "classification"
              ],
              "properties": {
                "classification": {
                  "const": "sanitization-required"
                }
              }
            },
            "then": {
              "properties": {
                "sanitized": {
                  "const": true
                }
              }
            }
          }
        ]
      }
    }
  ]
}
