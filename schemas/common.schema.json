{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./common.schema.json",
  "title": "Common SEO OS schema definitions",
  "description": "Shared JSON Schema definitions for gpante-seo-os record contracts.",
  "$defs": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "iso_date": {
      "oneOf": [
        {
          "type": "string",
          "const": "YYYY-MM-DD"
        },
        {
          "type": "string",
          "format": "date"
        }
      ]
    },
    "real_iso_date": {
      "type": "string",
      "format": "date"
    },
    "decision_id": {
      "type": "string",
      "pattern": "^DEC-[0-9]{4}-[0-9]{3}$"
    },
    "decision_id_template": {
      "type": "string",
      "enum": [
        "DEC-YYYY-NNN"
      ]
    },
    "task_id": {
      "type": "string",
      "pattern": "^TSK-[0-9]{4}-[0-9]{3}$"
    },
    "task_id_template": {
      "type": "string",
      "enum": [
        "TSK-YYYY-NNN"
      ]
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^EV-[0-9]{3}$"
    },
    "evidence_id_template": {
      "type": "string",
      "enum": [
        "EV-NNN"
      ]
    },
    "finding_id": {
      "type": "string",
      "pattern": "^FND-[0-9]{3}$"
    },
    "finding_id_template": {
      "type": "string",
      "enum": [
        "FND-NNN"
      ]
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "run_id_template": {
      "type": "string",
      "enum": [
        "YYYY-MM-DD-short-slug"
      ]
    },
    "nullable_run_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "common.schema.json#/$defs/run_id"
        }
      ]
    },
    "nullable_run_id_template": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "common.schema.json#/$defs/run_id_template"
        }
      ]
    },
    "nullable_decision_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "common.schema.json#/$defs/decision_id"
        }
      ]
    },
    "nullable_decision_id_template": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "common.schema.json#/$defs/decision_id_template"
        }
      ]
    },
    "task_id_array": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/task_id"
      },
      "uniqueItems": true
    },
    "task_id_array_template": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "common.schema.json#/$defs/task_id"
          },
          {
            "$ref": "common.schema.json#/$defs/task_id_template"
          }
        ]
      },
      "uniqueItems": true
    },
    "finding_id_array": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/finding_id"
      },
      "uniqueItems": true
    },
    "finding_id_array_template": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "common.schema.json#/$defs/finding_id"
          },
          {
            "$ref": "common.schema.json#/$defs/finding_id_template"
          }
        ]
      },
      "uniqueItems": true
    },
    "evidence_id_array": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/evidence_id"
      },
      "uniqueItems": true
    },
    "evidence_id_array_template": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "common.schema.json#/$defs/evidence_id"
          },
          {
            "$ref": "common.schema.json#/$defs/evidence_id_template"
          }
        ]
      },
      "uniqueItems": true
    },
    "decision_id_array": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/decision_id"
      },
      "uniqueItems": true
    },
    "decision_id_array_template": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "common.schema.json#/$defs/decision_id"
          },
          {
            "$ref": "common.schema.json#/$defs/decision_id_template"
          }
        ]
      },
      "uniqueItems": true
    },
    "risk": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High"
      ]
    },
    "approval_status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "not_required"
      ]
    },
    "validation_status": {
      "type": "string",
      "enum": [
        "pending",
        "passed",
        "failed",
        "inconclusive",
        "not_applicable"
      ],
      "$comment": "Canonical meanings are owned by workflows/status-definitions.md."
    },
    "decision_status": {
      "type": "string",
      "enum": [
        "proposed",
        "approved",
        "rejected",
        "superseded"
      ],
      "$comment": "Canonical meanings are owned by workflows/status-definitions.md."
    },
    "task_status": {
      "type": "string",
      "enum": [
        "proposed",
        "approved",
        "ready",
        "in_progress",
        "validation_pending",
        "completed",
        "blocked",
        "rejected",
        "cancelled",
        "rolled_back"
      ],
      "$comment": "Canonical meanings are owned by workflows/status-definitions.md."
    },
    "finding_status": {
      "type": "string",
      "enum": [
        "draft",
        "confirmed",
        "deferred",
        "resolved",
        "rejected",
        "superseded"
      ],
      "$comment": "Canonical meanings are owned by workflows/status-definitions.md."
    },
    "run_status": {
      "type": "string",
      "enum": [
        "initialized",
        "in_progress",
        "blocked",
        "completed",
        "cancelled",
        "archived"
      ],
      "$comment": "Canonical meanings are owned by workflows/status-definitions.md."
    },
    "workflow_stage": {
      "type": "string",
      "enum": [
        "intake",
        "scope",
        "evidence",
        "analysis",
        "findings",
        "prioritization",
        "decisions",
        "task_definition",
        "approval",
        "implementation",
        "validation",
        "monitoring",
        "closed"
      ],
      "$comment": "Canonical meanings are owned by workflows/status-definitions.md."
    },
    "real_owner": {
      "type": "string",
      "minLength": 1,
      "not": {
        "const": "OWNER_REQUIRED"
      }
    },
    "template_owner": {
      "type": "string",
      "const": "OWNER_REQUIRED"
    }
  }
}
